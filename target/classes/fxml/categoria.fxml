<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.gestorcontactos.controller.CategoriaController"
           prefWidth="600" prefHeight="600">

    <VBox styleClass="modal-card" alignment="TOP_CENTER"
          maxHeight="580">

        <!-- CABEÇALHO -->
        <HBox styleClass="modal-header" alignment="CENTER_LEFT">
            <Label text="Gerir Categorias" styleClass="modal-title"
                   HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="btn-close" onAction="#fechar"/>
        </HBox>

        <!-- CORPO -->
        <ScrollPane styleClass="scroll-pane"
                    fitToWidth="true" VBox.vgrow="ALWAYS">

            <VBox styleClass="modal-body" spacing="14">

                <!-- Campo nome -->
                <VBox spacing="6">
                    <Label text="Nome da categoria" styleClass="field-label"/>
                    <TextField fx:id="campoNome" styleClass="form-field"
                               promptText="Ex: Trabalho"/>
                </VBox>

                <!-- Campo descrição -->
                <VBox spacing="6">
                    <Label text="Descrição opcional" styleClass="field-label"/>
                    <TextField fx:id="campoDescricao" styleClass="form-field"
                               promptText="Ex: Contactos profissionais"/>
                </VBox>

                <!-- Erro -->
                <Label fx:id="lblErro" styleClass="error-label"
                       text="" visible="false" managed="false"/>

                <!-- Botão criar -->
                <Button text="＋  Criar Categoria"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        minHeight="46"
                        onAction="#criarCategoria"/>

                <!-- Divisor -->
                <HBox alignment="CENTER" spacing="10">
                    <padding><Insets top="8" bottom="4"/></padding>
                    <Region HBox.hgrow="ALWAYS" styleClass="section-line"
                            maxHeight="1"/>
                    <Label text="CATEGORIAS EXISTENTES"
                           styleClass="modal-section-label"/>
                    <Region HBox.hgrow="ALWAYS" styleClass="section-line"
                            maxHeight="1"/>
                </HBox>

                <!-- Lista de categorias -->
                <VBox fx:id="listaCategorias" spacing="8"/>

            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>