<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.CadastroController"
      fx:id="rootPane"
      prefWidth="1200" prefHeight="750"
      fillHeight="true">

    <!-- COLUNA ESQUERDA -->
    <VBox styleClass="login-left"
          prefWidth="500" minWidth="420"
          alignment="CENTER" spacing="24"
          HBox.hgrow="SOMETIMES">
        <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

        <ImageView fitWidth="320" fitHeight="260" preserveRatio="true">
            <image>
                <Image url="@../images/img_fundo_2.png"/>
            </image>
        </ImageView>

        <VBox spacing="12" alignment="CENTER">
            <Label text="Cria a tua conta em segundos."
                   styleClass="login-tagline" wrapText="true"
                   textAlignment="CENTER" maxWidth="340"/>
            <Label text="Regista-te e começa a organizar os teus contactos de forma eficiente."
                   styleClass="login-tagline-sub" wrapText="true"
                   textAlignment="CENTER" maxWidth="340"/>
        </VBox>
    </VBox>

    <!-- COLUNA DIREITA — Formulário de cadastro -->
    <VBox styleClass="login-right" alignment="CENTER" HBox.hgrow="ALWAYS">
        <padding><Insets top="0" right="90" bottom="0" left="90"/></padding>

        <VBox spacing="28" maxWidth="400">

            <VBox spacing="8">
                <Label text="GestorContactos" styleClass="login-app-title"/>
                <Label text="Cria a tua conta gratuitamente."
                       styleClass="login-app-sub"/>
            </VBox>

            <VBox spacing="14">

                <!-- Nome completo -->
                <VBox spacing="6">
                    <Label text="Nome Completo" styleClass="field-label"/>
                    <HBox styleClass="field-wrapper" alignment="CENTER_LEFT"
                          minHeight="48">
                        <Label text="👤" styleClass="field-icon"/>
                        <TextField fx:id="campoNome"
                                   styleClass="inner-field"
                                   promptText="Ex: Ana Silva"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="field-label"/>
                    <HBox styleClass="field-wrapper" alignment="CENTER_LEFT"
                          minHeight="48">
                        <Label text="@" styleClass="field-icon"/>
                        <TextField fx:id="campoUsername"
                                   styleClass="inner-field"
                                   promptText="Ex: ana.silva"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Senha -->
                <VBox spacing="6">
                    <Label text="Senha" styleClass="field-label"/>
                    <HBox styleClass="field-wrapper" alignment="CENTER_LEFT"
                          minHeight="48">
                        <Label text="🔒" styleClass="field-icon"/>
                        <PasswordField fx:id="campoSenha"
                                       styleClass="inner-field"
                                       promptText="Mínimo 4 caracteres"
                                       HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="campoSenhaVisivel"
                                   styleClass="inner-field"
                                   visible="false" managed="false"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnMostrarSenha" text="👁"
                                styleClass="btn-eye"
                                onAction="#toggleSenha"/>
                    </HBox>
                </VBox>

                <!-- Confirmar senha -->
                <VBox spacing="6">
                    <Label text="Confirmar Senha" styleClass="field-label"/>
                    <HBox styleClass="field-wrapper" alignment="CENTER_LEFT"
                          minHeight="48">
                        <Label text="🔒" styleClass="field-icon"/>
                        <PasswordField fx:id="campoConfirmar"
                                       styleClass="inner-field"
                                       promptText="Repete a senha"
                                       HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Erro -->
                <Label fx:id="lblErro" styleClass="error-label"
                       text="" wrapText="true"
                       visible="false" managed="false"/>

                <!-- Botão Criar Conta -->
                <Button text="+ Criar Conta"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        minHeight="48"
                        onAction="#criarConta"/>

            </VBox>

            <!-- Link para login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Já tens conta?" styleClass="login-app-sub"/>
                <Button text="Faz login"
                        styleClass="login-link"
                        onAction="#irParaLogin"/>
            </HBox>

        </VBox>
    </VBox>
</HBox>