<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gestorcontactos.controller.LoginController"
      fx:id="rootPane"
      prefWidth="1200" prefHeight="750"
      fillHeight="true">

    <!-- COLUNA ESQUERDA — Fundo escuro com imagem -->
    <VBox styleClass="login-left"
          prefWidth="500" minWidth="420"
          alignment="CENTER" spacing="24"
          HBox.hgrow="SOMETIMES">
        <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

        <!-- Ilustração -->
        <ImageView fx:id="ilustracao"
                   fitWidth="320" fitHeight="260"
                   preserveRatio="true">
            <image>
                <Image url="@../images/img_fundo_1.png"/>
            </image>
        </ImageView>

        <VBox spacing="12" alignment="CENTER">
            <Label text="Os teus contactos, organizados."
                   styleClass="login-tagline"
                   wrapText="true"
                   textAlignment="CENTER"
                   maxWidth="340"/>
            <Label text="A plataforma centralizada para gerir a tua rede profissional e pessoal com eficiência e segurança."
                   styleClass="login-tagline-sub"
                   wrapText="true"
                   textAlignment="CENTER"
                   maxWidth="340"/>
        </VBox>
    </VBox>

    <!-- COLUNA DIREITA — Formulário de login -->
    <VBox styleClass="login-right"
          alignment="CENTER"
          HBox.hgrow="ALWAYS">
        <padding><Insets top="0" right="90" bottom="0" left="90"/></padding>

        <VBox spacing="32" maxWidth="400">

            <!-- Título -->
            <VBox spacing="8">
                <Label text="GestorContactos" styleClass="login-app-title"/>
                <Label text="Inicia sessão para gerir os teus contactos."
                       styleClass="login-app-sub"/>
            </VBox>

            <!-- Campos do formulário -->
            <VBox spacing="16">

                <!-- Campo username -->
                <VBox spacing="6">
                    <HBox styleClass="field-wrapper" alignment="CENTER_LEFT"
                          minHeight="48">
                        <Label text="👤" styleClass="field-icon"/>
                        <TextField fx:id="campoUsername"
                                   styleClass="inner-field"
                                   promptText="Nome de utilizador"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Campo senha -->
                <VBox spacing="6">
                    <StackPane>
                        <HBox styleClass="field-wrapper" alignment="CENTER_LEFT"
                              minHeight="48">
                            <Label text="🔒" styleClass="field-icon"/>
                            <PasswordField fx:id="campoSenha"
                                          styleClass="inner-field"
                                          promptText="Palavra-passe"
                                          HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="campoSenhaVisivel"
                                       styleClass="inner-field"
                                       promptText="Palavra-passe"
                                       visible="false" managed="false"
                                       HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnMostrarSenha"
                                    text="👁" styleClass="btn-eye"
                                    onAction="#toggleSenha"/>
                        </HBox>
                    </StackPane>
                </VBox>

                <!-- Lembrar + Esqueceu -->
                <HBox alignment="CENTER_LEFT" spacing="0">
                    <CheckBox fx:id="chkLembrar"
                              text="Lembrar-me"
                              styleClass="login-check"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Esqueceu a senha?"
                            styleClass="forgot-link"
                            onAction="#esqueceuSenha"/>
                </HBox>

                <!-- Mensagem de erro -->
                <Label fx:id="lblErro" styleClass="error-label"
                       text="" wrapText="true" visible="false" managed="false"/>

                <!-- Botão Entrar -->
                <Button text="Entrar"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        minHeight="48"
                        onAction="#fazerLogin"/>

            </VBox>

            <!-- Link de registo -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Não tens conta?" styleClass="login-app-sub"/>
                <Button text="Regista-te"
                        styleClass="login-link"
                        onAction="#irParaCadastro"/>
            </HBox>

        </VBox>
    </VBox>
</HBox>